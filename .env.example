# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — set to 'postgresql' to switch away from SQLite
DATABASE_ENGINE=sqlite

# PostgreSQL (only needed when DATABASE_ENGINE=postgresql)
DB_NAME=guest_management
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# WhatsApp — Meta Cloud API via PyWA
# Get these from Meta Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=guest_management_verify
WHATSAPP_PASS_TEMPLATE=tws_guestpass

# Public base URL used to build pass image links sent to Meta (must be publicly accessible)
# e.g. https://yourdomain.com  — no trailing slash
WHATSAPP_MEDIA_BASE_URL=
